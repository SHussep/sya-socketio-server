    "archiver": "^7.0.1",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "dropbox": "^10.34.0",
    "express": "^4.18.2",
    "firebase-admin": "^13.5.0",
    "google-auth-library": "^10.4.1",
    "helmet": "^8.1.0",
    "imapflow": "^1.2.15",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^4.0.1",
    "mailparser": "^3.9.4",
    "node-fetch": "^2.7.0",
    "nodemailer": "^7.0.12",
    "pg": "^8.11.3",
    "socket.io": "^4.7.2"
