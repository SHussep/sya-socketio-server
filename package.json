{
  "name": "sya-tortillerias-socketio",
  "version": "1.0.0",
  "description": "Socket.IO server for real-time communication between Desktop POS and Mobile App",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "list-no-password": "node list_employees_without_password.js",
    "set-password": "node set_employee_password.js",
    "test": "jest --runInBand --forceExit",
    "test:multi-branch": "jest tests/multi-branch.test.js --runInBand --forceExit",
    "test:qa": "jest tests/multi-caja-qa.test.js --runInBand --forceExit --testTimeout=120000"
  },
  "keywords": [
    "socketio",
    "realtime",
    "pos",
    "notifications"
  ],
  "author": "SYA Tortillerías",
  "license": "ISC",
