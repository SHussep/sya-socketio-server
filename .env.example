# ═══════════════════════════════════════════════════════════════
# sya-socketio-server .env.example
# Plantilla sin secretos reales. Copia a `.env` y rellena valores.
# ═══════════════════════════════════════════════════════════════

# ── Super-Admin JWT (RS256) ──────────────────────────────────────
# Paths ABSOLUTOS a los PEMs generados en keys/ (ver keys/README.md).
# NO commitear los .pem; sólo referenciarlos aquí.
SUPER_ADMIN_PRIVATE_KEY_PATH=/absolute/path/to/super-admin-private.pem
SUPER_ADMIN_PUBLIC_KEY_PATH=/absolute/path/to/super-admin-public.pem

# Lista CSV de IPs permitidas para llamar a endpoints super-admin.
# Vacío = permitir todas (apropiado detrás de un VPN/proxy confiable).
SUPER_ADMIN_IP_ALLOWLIST=

# HMAC secret usado por endpoints de backup (Task 25+).
BACKUP_UPLOAD_SECRET=
